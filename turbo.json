{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "env": ["VITE_UMAMI_ID", "VITE_BACKEND_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env"]
    },
    "check": {
      "dependsOn": ["tsc", "lint", "format"]
    },
    "tsc": {
      "dependsOn": ["^tsc"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": [
        "DATABASE_URL",
        "BASE_URL",
        "FRONTEND_URL",
        "BETTER_AUTH_SECRET",
        "VITE_BACKEND_URL",
        "VITE_DEV"
      ]
    },
    "dev:search": {
      "with": ["@services/lcax#dev", "@lcax/ui#dev", "@lcax/search#dev"],
      "persistent": true,
      "cache": false,
      "env": [
        "DATABASE_URL",
        "BASE_URL",
        "FRONTEND_URL",
        "BETTER_AUTH_SECRET",
        "VITE_BACKEND_URL",
        "VITE_DEV"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}